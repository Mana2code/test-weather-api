              "host": ["{{base_url}}"],
              "path": ["current.json"],
              "query": [
                { "key": "key", "value": "{{api_key}}" },
                { "key": "q", "value": "ZZZNOWHERE999" },
                { "key": "aqi", "value": "yes" }
              ]
            }
          }
        }
      ]
    }
  ]
}
